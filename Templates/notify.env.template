# notify.env — rename this file to notify.env and fill in your webhook URL.
# Place it in the directory you run notify from, or pass it explicitly with --env-file.
# Keep this file out of source control — add notify.env to your .gitignore.
#
# Get the webhook URL from Teams: channel → ... → Workflows →
# "Send webhook alerts to a channel"

NOTIFY_TEAMS_WEBHOOK_URL=
