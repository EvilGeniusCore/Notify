# teams-notify test credentials
# Copy this file to test.env and fill in the values.
# test.env is gitignored — do not commit it.

# Entra ID tenant ID
# Found in: Azure Portal > Microsoft Entra ID > Overview > Tenant ID
TEAMS_NOTIFY_TENANT_ID=

# App Registration client ID
# Found in: Azure Portal > Microsoft Entra ID > App registrations > teams-notify > Overview > Application (client) ID
TEAMS_NOTIFY_CLIENT_ID=

# App Registration client secret
# Found in: Azure Portal > Microsoft Entra ID > App registrations > teams-notify > Certificates & secrets
TEAMS_NOTIFY_CLIENT_SECRET=

# Target team name or ID for the test send
# Run 'teams-notify list' after filling in the credentials above to find your team ID
TEAMS_NOTIFY_DEFAULT_TEAM=

# Target channel name or ID for the test send
# Run 'teams-notify list --team <your-team>' to see channels
TEAMS_NOTIFY_DEFAULT_CHANNEL=
