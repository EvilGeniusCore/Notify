# notify test credentials
# Copy this file to test.env and fill in the values.
# test.env is gitignored — do not commit it.

# Entra ID tenant ID
# Found in: Azure Portal > Microsoft Entra ID > Overview > Tenant ID
NOTIFY_TEAMS_TENANT_ID=

# App Registration client ID
# Found in: Azure Portal > Microsoft Entra ID > App registrations > notify > Overview > Application (client) ID
NOTIFY_TEAMS_CLIENT_ID=

# App Registration client secret
# Found in: Azure Portal > Microsoft Entra ID > App registrations > notify > Certificates & secrets
NOTIFY_TEAMS_CLIENT_SECRET=

# Target team name or ID for the test send
# Run 'notify list' after filling in the credentials above to find your team ID
NOTIFY_TEAMS_DEFAULT_TEAM=

# Target channel name or ID for the test send
# Run 'notify list --team <your-team>' to see channels
NOTIFY_TEAMS_DEFAULT_CHANNEL=
