# Normalize line endings to LF on commit, checkout as LF on all platforms
* text=auto eol=lf

# Windows batch/PowerShell — keep CRLF on Windows checkout
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly LF
*.cs text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.sln text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.pubxml text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.dll binary
*.exe binary
*.pdb binary
