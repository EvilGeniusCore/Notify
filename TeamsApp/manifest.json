{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "REPLACE-WITH-NEW-GUID",
  "packageName": "com.evilgeniuscore.notify.teams",
  "developer": {
    "name": "EvilGeniusCore",
    "websiteUrl": "https://github.com/EvilGeniusCore/Notify",
    "privacyUrl": "https://github.com/EvilGeniusCore/Notify",
    "termsOfUseUrl": "https://github.com/EvilGeniusCore/Notify"
  },
  "name": {
    "short": "notify",
    "full": "notify — Automated Channel Notifications"
  },
  "description": {
    "short": "Send automated notifications to this team from scripts and pipelines.",
    "full": "notify is a cross-platform CLI tool and .NET library for sending automated Microsoft Teams channel messages from CI/CD pipelines, cron jobs, and scripts. Install this app in a team to grant it permission to post notifications to any channel in that team."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "ChannelMessage.Send.Group",
          "type": "Application"
        }
      ]
    }
  },
  "validDomains": []
}
